{
  "name": "@flowvision/desktop",
  "version": "1.2.0",
  "private": true,
  "description": "AI 驱动的智能流程图设计工具 — 桌面端",
  "author": "YangXiaoMian",
  "repository": {
    "type": "git",
    "url": "https://github.com/YangXiaoMian/FlowVision.git"
  },
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.flowvision.app",
    "productName": "FlowVision",
    "icon": "../../logo/logo_512.png",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../../logo",
        "to": "logo",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/dist/server.bundle.mjs",
        "to": "backend/server.bundle.mjs"
      }
    ],
    "win": {
      "icon": "../../logo/logo_512.png",
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}"
    },
    "mac": {
      "icon": "../../logo/logo_512.png",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "icon": "../../logo/logo_512.png",
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
